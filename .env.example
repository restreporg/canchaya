APP_NAME="CanchaYa"
APP_ENV="local"
APP_KEY=
APP_DEBUG=false
APP_URL="http://canchaya.test"
APP_LOCALE="es"
APP_FALLBACK_LOCALE="es"
APP_FAKER_LOCALE="es_LA"
APP_MAINTENANCE_DRIVER="file"

BCRYPT_ROUNDS="12"

LOG_CHANNEL="stack"
LOG_STACK="single"
LOG_DEPRECATIONS_CHANNEL="null"
LOG_LEVEL="debug"

DB_CONNECTION="mysql"
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_DATABASE="canchaya"
DB_USERNAME="root"
DB_PASSWORD=

SESSION_DRIVER="database"
SESSION_LIFETIME="120"
SESSION_ENCRYPT=false
SESSION_PATH="/"
SESSION_DOMAIN=null

BROADCAST_CONNECTION="log"
FILESYSTEM_DISK="backblaze"
QUEUE_CONNECTION="database"
CACHE_STORE="database"

MEMCACHED_HOST="127.0.0.1"

REDIS_CLIENT="phpredis"
REDIS_HOST="127.0.0.1"
REDIS_PASSWORD=null
REDIS_PORT="6379"

SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0

MAIL_MAILER="log"
MAIL_HOST="127.0.0.1"
MAIL_PORT="2525"
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

B2_ACCESS_KEY_ID=
B2_SECRET_ACCESS_KEY=
B2_DEFAULT_REGION="us-east-005"
B2_BUCKET=
B2_ENDPOINT=
B2_URL=

VITE_APP_NAME="${APP_NAME}"